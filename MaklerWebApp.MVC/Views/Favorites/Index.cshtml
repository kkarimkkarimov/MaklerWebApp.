@model FavoritesIndexViewModel

@{
    ViewData["Title"] = "Seçilmiş elanlar";
}

<section class="mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="hero-title fs-2 mb-1">Seçilmiş elanlar</h1>
        <p class="hero-subtitle mb-0">Bəyəndiyiniz elanlara daha tez qayıdın.</p>
    </div>
    <a asp-controller="Listings" asp-action="Index" class="btn btn-outline-secondary">Elanlara qayıt</a>
</section>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<section class="filter-panel">
    @if (Model.Items.Count == 0)
    {
        <div class="empty-state">
            <h3 class="h5 mb-2">Seçilmiş elan yoxdur</h3>
            <p class="text-muted mb-0">Elan kartından və ya elan səhifəsindən seçilmişlərə əlavə edin.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model.Items)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <article class="listing-card h-100">
                        <div class="listing-card-image-wrap">
                            <img src="@item.ImageUrl" alt="@item.Title" class="listing-card-image" loading="lazy" />
                        </div>
                        <div class="listing-card-body">
                            <h3 class="listing-card-title">@item.Title</h3>
                            <p class="listing-card-location">@item.Location</p>
                            <p class="listing-card-price">@item.Price.ToString("N0") AZN</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <a asp-controller="Listings" asp-action="Details" asp-route-id="@item.ListingId" class="listing-card-link">Ətraflı bax</a>
                                <form asp-action="Remove" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="listingId" value="@item.ListingId" />
                                    <input type="hidden" name="returnUrl" value="@Url.Action("Index")" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                                </form>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</section>
