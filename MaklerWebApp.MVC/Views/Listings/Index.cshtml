@model ListingsIndexViewModel

@{
    ViewData["Title"] = "Elanlar";
}

<section class="mb-4">
    <h1 class="hero-title fs-2 mb-2">Elanlar</h1>
    <p class="hero-subtitle mb-0">Filtrlərdən istifadə edərək sizə uyğun daşınmaz əmlakı daha sürətli tapın.</p>
</section>

<div class="row g-4">
    <aside class="col-12 col-lg-3">
        <form method="get" class="filter-panel">
            <div class="mb-3">
                <label asp-for="Filters.Keyword" class="form-label">Açar söz</label>
                <input asp-for="Filters.Keyword" class="form-control" placeholder="Məs: Yeni tikili" />
            </div>

            <div class="mb-3">
                <label asp-for="Filters.City" class="form-label">Şəhər</label>
                <input asp-for="Filters.City" class="form-control" placeholder="Məs: Bakı" />
            </div>

            <div class="row g-2 mb-3">
                <div class="col-6">
                    <label asp-for="Filters.MinPrice" class="form-label">Min qiymət</label>
                    <input asp-for="Filters.MinPrice" class="form-control" />
                </div>
                <div class="col-6">
                    <label asp-for="Filters.MaxPrice" class="form-label">Max qiymət</label>
                    <input asp-for="Filters.MaxPrice" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Filters.SortBy" class="form-label">Sıralama</label>
                <select asp-for="Filters.SortBy" class="form-select">
                    <option value="published">Yeni elanlar</option>
                    <option value="price">Qiymət</option>
                    <option value="area">Sahə</option>
                </select>
            </div>

            <div class="form-check mb-3">
                <input asp-for="Filters.Descending" class="form-check-input" />
                <label asp-for="Filters.Descending" class="form-check-label">Azalan sıra</label>
            </div>

            <input asp-for="Filters.Page" type="hidden" value="1" />
            <input asp-for="Filters.PageSize" type="hidden" />

            <button type="submit" class="btn btn-brand w-100">Axtar</button>
        </form>
    </aside>

    <section class="col-12 col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <p class="mb-0 text-muted">Tapıldı: <strong>@Model.TotalCount</strong> elan</p>
        </div>

        @if (Model.Items.Count == 0)
        {
            <div class="empty-state">
                <h3 class="h5 mb-2">Elan tapılmadı</h3>
                <p class="text-muted mb-0">Filtrləri dəyişərək yenidən cəhd edin.</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in Model.Items)
                {
                    <div class="col-12 col-md-6">
                        <partial name="_ListingCard" model="item" />
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4" aria-label="Pagination">
                    <ul class="pagination pagination-modern mb-0">
                        @for (var p = 1; p <= Model.TotalPages; p++)
                        {
                            var pageUrl = Url.Action("Index", new
                            {
                                keyword = Model.Filters.Keyword,
                                city = Model.Filters.City,
                                minPrice = Model.Filters.MinPrice,
                                maxPrice = Model.Filters.MaxPrice,
                                sortBy = Model.Filters.SortBy,
                                descending = Model.Filters.Descending,
                                page = p,
                                pageSize = Model.PageSize
                            });

                            <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                                <a class="page-link" href="@pageUrl">@p</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </section>
</div>
