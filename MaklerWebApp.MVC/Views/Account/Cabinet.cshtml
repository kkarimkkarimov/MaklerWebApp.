@model CabinetViewModel

@{
    ViewData["Title"] = "Şəxsi kabinet";
}

<section class="mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="hero-title fs-2 mb-1">Şəxsi kabinet</h1>
        <p class="hero-subtitle mb-0">Ödəniş tarixçəniz və hesab məlumatlarınız.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Profile" class="btn btn-outline-secondary">Profil</a>
        <a asp-controller="Favorites" asp-action="Index" class="btn btn-outline-secondary">Seçilmişlər</a>
        <a asp-action="MyListings" class="btn btn-brand">Mənim elanlarım</a>
        <form asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary">Çıxış</button>
        </form>
    </div>
</section>

<section class="stats-grid mb-4">
    <div class="stat-card">
        <p class="stat-value">@Model.TotalListingsCount</p>
        <p class="stat-label">Ümumi elan sayı</p>
    </div>
    <div class="stat-card">
        <p class="stat-value">@Model.FeaturedListingsCount</p>
        <p class="stat-label">Featured elanlar</p>
    </div>
    <div class="stat-card">
        <p class="stat-value">@Model.TotalPaymentAmount.ToString("N2") AZN</p>
        <p class="stat-label">Ümumi ödəniş məbləği</p>
    </div>
</section>

<section class="filter-panel mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="section-title mb-0">Son elanlar</h2>
        <a asp-action="MyListings" class="text-decoration-none">Hamısına bax</a>
    </div>

    @if (Model.RecentListings.Count == 0)
    {
        <div class="empty-state">
            <h3 class="h5 mb-2">Hələ elan yoxdur</h3>
            <p class="text-muted mb-0">İlk elanınızı əlavə etdikdən sonra burada görünəcək.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Elan</th>
                        <th>Qiymət</th>
                        <th>Status</th>
                        <th>Tarix</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.RecentListings)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.Title</div>
                                <div class="text-muted small">@item.Location</div>
                            </td>
                            <td>@item.Price.ToString("N0") @item.Currency</td>
                            <td>
                                <span class="status-badge @item.StatusClass">@item.StatusLabel</span>
                            </td>
                            <td>@item.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td><a href="@item.DetailsUrl" class="text-decoration-none">Bax</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="filter-panel">
    <h2 class="section-title">Ödəniş tarixçəsi</h2>

    @if (Model.PaymentHistory.Count == 0)
    {
        <div class="empty-state">
            <h3 class="h5 mb-2">Hələ ödəniş yoxdur</h3>
            <p class="text-muted mb-0">Boost/VIP xidmətləri istifadə etdikcə tarixçə burada görünəcək.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Listing</th>
                        <th>Məbləğ</th>
                        <th>Status</th>
                        <th>Tarix</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.PaymentHistory)
                    {
                        var paymentStatus = item.Status switch
                        {
                            1 => "Pending",
                            2 => "Success",
                            3 => "Failed",
                            _ => "Unknown"
                        };

                        <tr>
                            <td>@item.Id</td>
                            <td>@item.ListingId</td>
                            <td>@item.Amount.ToString("N2") AZN</td>
                            <td>@paymentStatus</td>
                            <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
