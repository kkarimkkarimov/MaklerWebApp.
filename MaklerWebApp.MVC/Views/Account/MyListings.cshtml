@model MyListingsViewModel

@{
    ViewData["Title"] = "Mənim elanlarım";
}

<section class="mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="hero-title fs-2 mb-1">Mənim elanlarım</h1>
        <p class="hero-subtitle mb-0">Elanlarınızın statusunu və aktivliyini buradan idarə edin.</p>
    </div>
    <a asp-action="Cabinet" class="btn btn-outline-secondary">Kabinetə qayıt</a>
</section>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<section class="filter-panel">
    @if (Model.Items.Count == 0)
    {
        <div class="empty-state">
            <h3 class="h5 mb-2">Hələ elan yoxdur</h3>
            <p class="text-muted mb-0">Yeni elan əlavə etdikdə siyahıda görünəcək.</p>
            <a asp-controller="Listings" asp-action="Create" class="btn btn-brand mt-3">İlk elanı əlavə et</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Elan</th>
                        <th>Qiymət</th>
                        <th>Status</th>
                        <th>Tarix</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.Title</div>
                                <div class="text-muted small">@item.Location</div>
                            </td>
                            <td>@item.Price.ToString("N0") @item.Currency</td>
                            <td>
                                <span class="status-badge @item.StatusClass">@item.StatusLabel</span>
                            </td>
                            <td>@item.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    <a href="@item.DetailsUrl" class="btn btn-sm btn-outline-primary">Ətraflı</a>
                                    <a asp-controller="Listings" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Redaktə</a>
                                    <form asp-action="SetAdStatus" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="adStatus" value="1" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Aktiv et</button>
                                    </form>
                                    <form asp-action="SetAdStatus" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="adStatus" value="3" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning">Arxivlə</button>
                                    </form>
                                    <form asp-action="StartBoost" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <select name="serviceType" class="form-select form-select-sm d-inline-block" style="width: 120px;">
                                            <option value="1">VIP</option>
                                            <option value="2">Premium</option>
                                            <option value="3" selected>Boost</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-brand">Boost</button>
                                    </form>
                                    <form asp-action="DeleteListing" method="post" class="d-inline" onsubmit="return confirm('Elanı silmək istədiyinizə əminsiniz?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4" aria-label="Pagination">
                <ul class="pagination pagination-modern mb-0">
                    @for (var p = 1; p <= Model.TotalPages; p++)
                    {
                        var pageUrl = Url.Action("MyListings", new { page = p, pageSize = Model.PageSize });
                        <li class="page-item @(p == Model.Page ? "active" : string.Empty)">
                            <a class="page-link" href="@pageUrl">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</section>
