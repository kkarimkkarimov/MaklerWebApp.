@model VerifyOtpViewModel

@{
    ViewData["Title"] = "OTP Təsdiq";
}

<section class="auth-shell">
    <div class="auth-card">
        <h1 class="h3 mb-2">OTP təsdiqi</h1>
        <p class="text-muted mb-4">Email və ya telefonunuza göndərilən 6 rəqəmli kodu daxil edin.</p>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <form asp-action="VerifyOtp" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="EmailOrPhone" class="form-label"></label>
                <input asp-for="EmailOrPhone" class="form-control" />
                <span asp-validation-for="EmailOrPhone" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control" inputmode="numeric" maxlength="6" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-brand w-100">Təsdiqlə</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
