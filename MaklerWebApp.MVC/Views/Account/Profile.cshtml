@model ProfileViewModel

@{
    ViewData["Title"] = "Profil";
}

<section class="mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="hero-title fs-2 mb-1">Profil məlumatları</h1>
        <p class="hero-subtitle mb-0">Əlaqə və hesab məlumatlarınızı yeniləyin.</p>
    </div>
    <a asp-action="Cabinet" class="btn btn-outline-secondary">Kabinetə qayıt</a>
</section>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<section class="filter-panel">
    <form asp-action="Profile" method="post" novalidate>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" readonly />
            </div>
            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ProfileImageUrl" class="form-label"></label>
                <input asp-for="ProfileImageUrl" class="form-control" />
                <span asp-validation-for="ProfileImageUrl" class="text-danger"></span>
            </div>
            <div class="col-12">
                <span class="status-badge @(Model.IsVerified ? "badge-soft-success" : "badge-soft-warning")">
                    @(Model.IsVerified ? "Təsdiqlənmiş hesab" : "Hesab təsdiqlənməyib")
                </span>
            </div>
        </div>

        <button type="submit" class="btn btn-brand mt-4">Yadda saxla</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
