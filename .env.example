# API runtime secrets (do not commit real values)
Jwt__SecretKey=replace-with-32-byte-minimum-secret

# Optional API overrides
ConnectionStrings__DefaultConnection=Server=localhost;Database=MaklerWebAppDb;Trusted_Connection=True;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True

# MVC -> API endpoint
Api__BaseUrl=https://localhost:7110/
